{
  "name": "Modified Rocker Dev Container",
  "build": {
    "dockerfile": "Dockerfile.bioc",
    "context": ".."
  },
  "features": {
  	"ghcr.io/MiguelRodo/DevContainerFeatures/repos:2": {},
    "ghcr.io/MiguelRodo/DevContainerFeatures/renv-cache:1": {
      "debug": true,
      "debugRenv": true
    },
		"ghcr.io/devcontainers-extra/features/apt-get-packages:1": {
			"packages": "xvfb,vim,libcurl4-openssl-dev,libsecret-1-dev"
		},
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {
			"installTinyTex": true
		},
		"ghcr.io/MiguelRodo/DevContainerFeatures/mermaid:1": {}
  },
	"customizations": {
		"vscode": {
			"extensions": [
        "quarto.quarto",
        "GitHub.copilot",
        "GitHub.copilot-chat",
				"mathematic.vscode-pdf" 
			]
		}
	}
}
